# API base URL — must include /api/v1
VITE_API_BASE_URL=https://kab-grant-system.onrender.com/api/v1

# Grant calls for anonymous visitors are loaded from GET /api/v1/general/grant-calls
# (no token required). Optional: run npm run sync:grant-calls before deploy to refresh
# frontend/public/open-grant-calls.json as an offline fallback.
